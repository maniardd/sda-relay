      {
        "unique_name": "definition_activity_02UP4604KJH8S5MWBzTToiZsFZf6d6aXsME",
        "name": "Execute Python Script",
        "title": "Pre-Check - Device Health",
        "type": "python3.script",
        "base_type": "activity",
        "properties": {
          "action_timeout": 120,
          "continue_on_failure": true,
          "description": "Verify RESTCONF reachability on both switches via relay server.",
          "display_name": "Pre-Check - Device Health",
          "script": "import sys\nimport json\nimport requests\n\nrelay_url = sys.argv[1] if len(sys.argv) > 1 else \"\"\nfabric_name = sys.argv[2] if len(sys.argv) > 2 else \"\"\nforce = sys.argv[3] if len(sys.argv) > 3 else \"false\"\n\nurl = f\"{relay_url}/api/v2/precheck\"\npayload = {\"fabric_name\": fabric_name, \"force\": force.lower() == \"true\"}\n\ntry:\n    resp = requests.post(url, json=payload, timeout=60, verify=False)\n    result = resp.json()\n    status = result.get(\"status\", \"fail\")\n    succeeded = status == \"pass\"\n    result_json = json.dumps(result)\nexcept Exception as e:\n    succeeded = False\n    status = \"error\"\n    result_json = json.dumps({\"status\": \"error\", \"error\": str(e)})\n\nprint(result_json)",
          "script_arguments": [
            "$workflow.definition_workflow_02UP35U6XZOM17QTEpj6x2sevEr4LGrXVat.input.variable_workflow_02UP3OILZXQFC4aT5FWrHDlZLJWfx5IQGiR$",
            "$workflow.definition_workflow_02UP35U6XZOM17QTEpj6x2sevEr4LGrXVat.input.variable_workflow_02UP3YXNN21U32LucPagotCQNwPWynBzVob$",
            "$workflow.definition_workflow_02UP35U6XZOM17QTEpj6x2sevEr4LGrXVat.input.variable_workflow_02UP4012MLDU23eqRBmoO94jZGCdyhvCMxr$"
          ],
          "script_queries": [
            {
              "script_query": "succeeded",
              "script_query_name": "succeeded ",
              "script_query_type": "boolean"
            },
            {
              "script_query": "status",
              "script_query_name": "status",
              "script_query_type": "string"
            },
            {
              "script_query": "result_json",
              "script_query_name": "result_json",
              "script_query_type": "string"
            }
          ],
          "skip_execution": false
        },
