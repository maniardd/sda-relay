                    "name": "Execute Python Script",
                    "title": "Deploy Phase 1 - Underlay",
                    "type": "python3.script",
                    "base_type": "activity",
                    "properties": {
                      "action_timeout": 180,
                      "continue_on_failure": true,
                      "description": "Deploy ISIS underlay via RESTCONF relay.",
                      "display_name": "Deploy Phase 1 - Underlay",
                      "script": "import sys\nimport json\nimport requests\n\nrelay_url = sys.argv[1] if len(sys.argv) > 1 else \"\"\nfabric_name = sys.argv[2] if len(sys.argv) > 2 else \"\"\n\nurl = f\"{relay_url}/api/v2/deploy/phase1-underlay\"\npayload = {\"fabric_name\": fabric_name}\n\ntry:\n    resp = requests.post(url, json=payload, timeout=120, verify=False)\n    result = resp.json()\n    succeeded = resp.status_code == 200 and result.get(\"status\") != \"error\"\n    result_json = json.dumps(result)\nexcept Exception as e:\n    succeeded = False\n    result_json = json.dumps({\"status\": \"error\", \"error\": str(e)})\n\nprint(result_json)",
                      "script_arguments": [
                        "$workflow.definition_workflow_02UP35U6XZOM17QTEpj6x2sevEr4LGrXVat.input.variable_workflow_02UP3OILZXQFC4aT5FWrHDlZLJWfx5IQGiR$",
