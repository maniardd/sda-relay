                            "properties": {
                              "action_timeout": 120,
                              "continue_on_failure": true,
                              "description": "Wait 15s then verify ISIS/BFD/PIM neighbors.",
                              "display_name": "Verify Phase 1 - Underlay Health",
                              "script": "import sys\nimport json\nimport requests\nimport time\n\nrelay_url = sys.argv[1] if len(sys.argv) > 1 else \"\"\nfabric_name = sys.argv[2] if len(sys.argv) > 2 else \"\"\n\ntime.sleep(15)\n\nurl = f\"{relay_url}/api/v2/verify/phase1-underlay\"\npayload = {\"fabric_name\": fabric_name}\n\ntry:\n    resp = requests.post(url, json=payload, timeout=60, verify=False)\n    result = resp.json()\n    succeeded = result.get(\"status\") == \"pass\"\n    result_json = json.dumps(result)\nexcept Exception as e:\n    succeeded = False\n    result_json = json.dumps({\"status\": \"error\", \"error\": str(e)})\n\nprint(result_json)",
